# =========================
# APP
# =========================
APP_NAME="AI Trading Signal Assistant"
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT=8000
# Lokal:
DATABASE_URL="sqlite:///./signals.db"
# Supabase/Vercel production:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Jalankan scheduler otomatis setiap X menit.
ENABLE_SCHEDULER=false
SCAN_INTERVAL_MINUTES=60

# Pair aktif untuk scan otomatis. Pisahkan dengan koma.
ACTIVE_PAIRS="EUR_USD,GBP_USD,USD_JPY,XAU_USD,BTC_USDT"
DEFAULT_MODE="swing"
DEFAULT_BALANCE=1000
DEFAULT_ACCOUNT_TYPE="USD"
DEFAULT_RISK_PERCENT=1
MIN_CONFIDENCE=70

# =========================
# MARKET DATA
# =========================
# Sumber data/sinyal utama: TradingView Alert Webhook.
DATA_PROVIDER="tradingview"

# Opsional: isi secret dan kirim field "secret" yang sama dari alert TradingView.
TRADINGVIEW_WEBHOOK_SECRET=""

# =========================
# AI REASONING - OPTIONAL
# =========================
# Jika true, webhook akan meminta AI memberi reasoning tambahan dari payload TradingView.
ENABLE_AI_REASONING=false
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.2"
OPENAI_BASE_URL="https://api.openai.com/v1"

# =========================
# NOTIFICATION - TELEGRAM
# =========================
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# =========================
# NOTIFICATION - WHATSAPP CLOUD API
# =========================
# Kirim WhatsApp memerlukan Meta WhatsApp Business Cloud API.
# Untuk pesan proaktif di luar window 24 jam biasanya perlu template.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TO_NUMBER=""
WHATSAPP_API_VERSION="v23.0"

# Jika true, endpoint /api/send-alert akan coba kirim WhatsApp template.
# Jika false, akan kirim text message biasa. Text biasa hanya aman di window 24 jam setelah user menghubungi bisnis Anda.
WHATSAPP_USE_TEMPLATE=false
WHATSAPP_TEMPLATE_NAME="trading_signal_alert"
WHATSAPP_TEMPLATE_LANGUAGE="id"
